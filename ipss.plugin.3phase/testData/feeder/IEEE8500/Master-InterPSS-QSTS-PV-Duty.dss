// Master file for 8500-Node IEEE Test Feeder Case
// Balanced load case with DSS-Python-resolved linecodes, controlled-QSTS
// regulator limits, and an active EPRI PV duty profile.

Clear
Set DefaultBaseFrequency=60

New Circuit.IEEE8500

! Make the source stiff with small impedance
~ pu=1.05  r1=0  x1=0.001  r0=0  x0=0.001

Redirect  LineCodes2.DSS
Redirect  Triplex_Linecodes.dss
Redirect  DSSPythonLineCodes.dss

Redirect  Lines.dss
Redirect  Transformers.dss
//Redirect  LoadXfmrs.dss    ! Load Transformers
Redirect  LoadXfmrCodes.dss  ! Referencing XfmrCodes
Redirect  Triplex_Lines.DSS
Redirect  Loads.dss     ! Balanced Loads
Redirect  Capacitors.dss
Redirect  CapControls.DSS
Redirect  Regulators.dss

// Limit each static-control action to one regulator tap, matching the IEEE8500
// duty-study setup and avoiding OpenDSS regulator interaction non-convergence.
regcontrol.feeder_rega.maxtapchange=1  Delay=30
regcontrol.feeder_regb.maxtapchange=1  Delay=30
regcontrol.feeder_regc.maxtapchange=1  Delay=30
regcontrol.vreg2_a.maxtapchange=1  Delay=60
regcontrol.vreg2_b.maxtapchange=1  Delay=60
regcontrol.vreg2_c.maxtapchange=1  Delay=60
regcontrol.vreg3_a.maxtapchange=1  Delay=45
regcontrol.vreg3_b.maxtapchange=1  Delay=45
regcontrol.vreg3_c.maxtapchange=1  Delay=45
regcontrol.vreg4_a.maxtapchange=1  Delay=45
regcontrol.vreg4_b.maxtapchange=1  Delay=45
regcontrol.vreg4_c.maxtapchange=1  Delay=45

New Loadshape.PVCurve interval=(1.0 3600 /) npts=2900 mult=(File="Normalized-1s-2900-pts.CSV")
New generator.G1 Bus1=M1026891 kV=12.47 kW=360 pf=1.0 duty=PVcurve model=1

! Let DSS estimate the voltage bases
Set voltagebases=[115, 12.47,  0.48, 0.208]
Calcvoltagebases     ! This also establishes the bus list

! Load in bus coordintes now that bus list is established
Buscoords  Buscoords.dss
